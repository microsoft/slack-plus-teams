# --- Teams credentials ---
CLIENT_ID=your-teams-app-client-id
CLIENT_SECRET=your-teams-app-client-secret
TENANT_ID=your-azure-tenant-id
PORT=3978

# --- Slack credentials ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-level-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# --- Feature flags (optional) ---
ENABLE_EPHEMERAL=true
ENABLE_THREAD_BROADCAST=true
ENABLE_FILE_UPLOAD=true
ENABLE_CONFIRMATION=true

# --- Agents Toolkit vars ---
BOT_ID=your-teams-app-client-id
BOT_DOMAIN=your-bot-domain.azurewebsites.net
TEAMS_APP_ID=your-teams-app-id

# --- Logging ---
LOG_LEVEL=info
