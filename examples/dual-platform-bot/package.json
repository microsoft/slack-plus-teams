{
  "name": "dual-platform-bot",
  "version": "1.0.0",
  "description": "Production-ready dual-platform bot template for Slack and Microsoft Teams",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r dotenv/config dist/index.js",
    "dev": "tsx watch -r dotenv/config src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@microsoft/teams.api": "2.0.5",
    "@microsoft/teams.apps": "2.0.5",
    "@microsoft/teams.cards": "2.0.5",
    "@microsoft/teams.common": "2.0.5",
    "@microsoft/teams.dev": "2.0.5",
    "@microsoft/teams.graph": "2.0.5",
    "@slack/bolt": "^4.1.0",
    "@slack/web-api": "^7.8.0",
    "express": "^5.0.1",
    "p-queue": "^8.0.1"
  },
  "devDependencies": {
    "@microsoft/teams.config": "2.0.5",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
