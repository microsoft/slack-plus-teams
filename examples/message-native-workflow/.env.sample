# === Teams credentials ===
CLIENT_ID=your-azure-app-client-id
CLIENT_SECRET=your-azure-app-client-secret
TENANT_ID=your-azure-tenant-id

# === Agents Toolkit vars ===
BOT_ID=your-azure-app-client-id
BOT_DOMAIN=your-bot-domain.azurewebsites.net
TEAMS_APP_ID=your-teams-app-id

# === SharePoint site for workflow state ===
SHAREPOINT_SITE_ID=your-sharepoint-site-id

# === Azure OpenAI (for NL queries) ===
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# === Scheduled standup (cron expression, default: 9 AM weekdays) ===
STANDUP_CRON=0 9 * * 1-5

# === Server ===
PORT=3978
